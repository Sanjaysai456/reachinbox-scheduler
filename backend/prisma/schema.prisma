generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum EmailStatus {
  SCHEDULED
  SENT
  FAILED
}

model User {
  id        String     @id @default(cuid())
  googleId  String     @unique
  email     String     @unique
  name      String
  avatarUrl String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  campaigns Campaign[]
}

model Sender {
  id        String     @id @default(cuid())
  name      String
  email     String     @unique
  fromName  String?
  smtpHost  String
  smtpPort  Int
  smtpUser  String
  smtpPass  String
  secure    Boolean    @default(false)
  active    Boolean    @default(true)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  campaigns Campaign[]
  emails    EmailJob[]
}

model Campaign {
  id             String     @id @default(cuid())
  userId         String
  senderId       String
  subject        String
  body           String     @db.Text
  startTime      DateTime
  delayBetweenMs Int
  hourlyLimit    Int
  totalRecipients Int
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  user           User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  sender         Sender     @relation(fields: [senderId], references: [id], onDelete: Restrict)
  emails         EmailJob[]

  @@index([userId, createdAt])
}

model EmailJob {
  id                 String      @id @default(cuid())
  campaignId         String
  senderId           String
  recipientEmail     String
  subject            String
  body               String      @db.Text
  scheduledAt        DateTime
  sentAt             DateTime?
  failedAt           DateTime?
  status             EmailStatus @default(SCHEDULED)
  errorMessage       String?     @db.Text
  providerMessageId  String?
  etherealPreviewUrl String?
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt
  campaign           Campaign    @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  sender             Sender      @relation(fields: [senderId], references: [id], onDelete: Restrict)

  @@index([status, scheduledAt])
  @@index([campaignId, scheduledAt])
}
